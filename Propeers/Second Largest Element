#include <iostream>
#include <vector>
#include <climits>

class Solution {
public:
    int getSecondLargest(std::vector<int>& arr) {
        int n = arr.size();
        if (n == 0) return -1;

        int first = INT_MIN;
        int second = INT_MIN;

        // Loop 1: Find the largest element
        for (int i = 0; i < n; i++) {
            if (arr[i] > first) {
                first = arr[i];
            }
        }

        // Loop 2: Find the second largest element
        for (int i = 0; i < n; i++) {
            if (arr[i] > second && arr[i] < first) {
                second = arr[i];
            }
        }

        // Return second if found, otherwise return first (Example 3 logic)
        return (second == INT_MIN) ? first : second;
    }
};

int main() {
    Solution sol;
    std::vector<int> nums = {3, 1, 5, 7, 4};
    
    std::cout << "Result: " << sol.getSecondLargest(nums) << std::endl;
    
    return 0;
}
